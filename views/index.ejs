<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Fingerprint Proxy Integration E2E Tester</title>

  <!-- Tailwind via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'media',
      theme: {
        extend: {
          boxShadow: {
            'card': '0 1px 2px 0 rgb(0 0 0 / 0.06), 0 1px 3px 0 rgb(0 0 0 / 0.10)'
          }
        }
      }
    }
  </script>

  <!-- Vue 2.7 -->
  <script src="https://cdn.jsdelivr.net/npm/vue@2.7.16"></script>

  <!-- Lucide (free icon CDN, no CORS headaches) -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <style>
      :focus-visible { outline: 2px solid rgb(59 130 246); outline-offset: 2px; }
      html, body { height: 100%; }
      .input-wrap { position: relative; }
      .input-wrap i[data-lucide] { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); width: 1rem; height: 1rem; color: #9CA3AF; }
      .input-wrap input { padding-left: 2.25rem; }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 h-full">
<div id="app" class="max-w-7xl mx-auto p-4 h-full flex flex-col gap-3">

  <!-- Sticky action bar -->
  <div class="sticky top-0 z-30">
    <div class="backdrop-blur bg-white/80 dark:bg-gray-900/80 border border-gray-200 dark:border-gray-800 rounded-xl p-3 shadow-card">
      <div class="flex flex-wrap items-center gap-2">
        <button @click="handleSubmit"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white disabled:opacity-50 inline-flex items-center gap-2"
                :disabled="testResult.status==='pending' || testCases.length===0">
          <i data-lucide="play" class="w-4 h-4"></i>
          <span v-if="testResult.status!=='pending'">Run</span>
          <span v-else class="inline-flex items-center gap-2">
            <i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i>
            Running…
          </span>
        </button>

        <div class="flex items-center gap-2" aria-live="polite">
          <span class="text-sm font-medium">Status:</span>
          <span v-if="testResult.status==='initialize'" class="px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-800">Initialize</span>
          <span v-if="testResult.status==='pending'" class="px-2 py-1 text-xs rounded bg-amber-200 text-amber-900">Pending</span>
          <span v-if="testResult.status==='finished' && testResult.success" class="px-2 py-1 text-xs rounded bg-emerald-200 text-emerald-900">Success</span>
          <span v-if="testResult.status==='finished' && !testResult.success" class="px-2 py-1 text-xs rounded bg-rose-200 text-rose-900">Fail</span>
        </div>

        <div class="ml-auto flex flex-wrap gap-2">
          <a href="https://github.com/fingerprintjs/dx-team-mock-for-proxy-integrations-e2e-tests/blob/main/README.md"
             target="_blank"
             class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 inline-flex items-center gap-2">
            <i data-lucide="book-open" class="w-4 h-4"></i>
            Documentation
          </a>
          <button @click="copyFormValue" class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-700 inline-flex items-center gap-2">
            <i data-lucide="clipboard" class="w-4 h-4"></i>
            <span v-if="!copying">Copy Base64</span>
            <span v-else>Copied!</span>
          </button>
          <button @click="loadExample" class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-700 inline-flex items-center gap-2">
            <i data-lucide="sparkles" class="w-4 h-4"></i>
            Load Example
          </button>
          <button @click="resetForm" class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-700 inline-flex items-center gap-2">
            <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
            Reset
          </button>
          <button v-if="testResult.results.length" @click="exportResults"
                  class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-700 inline-flex items-center gap-2">
            <i data-lucide="download" class="w-4 h-4"></i>
            Export Results JSON
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Two-pane layout occupying remaining height -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 flex-1 min-h-0">
    <!-- Left: form (scrollable) -->
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 shadow-card bg-white dark:bg-gray-950 p-4 overflow-auto min-h-0">
      <div class="grid grid-cols-1 gap-4">

        <!-- Integration URL -->
        <div>
          <label for="integrationUrl" class="block text-sm font-medium">
            Integration URL <span class="text-gray-500 text-xs">(Required)</span>
          </label>
          <div
            class="mt-1 flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3"
            :class="{'ring-2 ring-rose-500': incorrectFields.includes('integrationUrl')}"
          >
            <i data-lucide="link-2" class="w-4 h-4 text-gray-400 shrink-0"></i>
            <input
              id="integrationUrl"
              v-model="formData.integrationUrl"
              type="text"
              class="flex-1 bg-transparent border-0 outline-none focus:ring-0 py-2"
              placeholder="https://mydomain.tld/integration-path"
              required
            >
          </div>
          <p class="text-xs text-gray-500 mt-1">Integration address of your proxy integration.</p>
        </div>

        <!-- Ingress/CDN -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="ingressPath" class="block text-sm font-medium">
              Ingress Path <span class="text-gray-500 text-xs">(Required)</span>
            </label>
            <div
              class="mt-1 flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3"
              :class="{'ring-2 ring-rose-500': incorrectFields.includes('ingressPath')}"
            >
              <i data-lucide="arrow-right-left" class="w-4 h-4 text-gray-400 shrink-0"></i>
              <input
                id="ingressPath"
                v-model="formData.ingressPath"
                type="text"
                class="flex-1 bg-transparent border-0 outline-none focus:ring-0 py-2"
                placeholder="ingress"
                required
              >
            </div>
            <p class="text-xs text-gray-500 mt-1">Ingress endpoint in your proxy integration.</p>
          </div>

          <div>
            <label for="cdnPath" class="block text-sm font-medium">
              CDN Path <span class="text-gray-500 text-xs">(Required)</span>
            </label>
            <div
              class="mt-1 flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3"
              :class="{'ring-2 ring-rose-500': incorrectFields.includes('cdnPath')}"
            >
              <i data-lucide="cloud" class="w-4 h-4 text-gray-400 shrink-0"></i>
              <input
                id="cdnPath"
                v-model="formData.cdnPath"
                type="text"
                class="flex-1 bg-transparent border-0 outline-none focus:ring-0 py-2"
                placeholder="cdn"
                required
              >
            </div>
            <p class="text-xs text-gray-500 mt-1">CDN endpoint in your proxy integration.</p>
          </div>
        </div>

        <!-- Traffic name / version -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="trafficName" class="block text-sm font-medium">Traffic Name</label>
            <div
              class="mt-1 flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3"
              :class="{'ring-2 ring-rose-500': incorrectFields.includes('trafficName')}"
            >
              <!-- traffic-light can be spotty; use 'tag' for a stable, relevant icon -->
              <i data-lucide="tag" class="w-4 h-4 text-gray-400 shrink-0"></i>
              <input
                id="trafficName"
                v-model="formData.trafficName"
                type="text"
                class="flex-1 bg-transparent border-0 outline-none focus:ring-0 py-2"
                placeholder="fingerprint-pro-acme-integration"
              >
            </div>
            <p class="text-xs text-gray-500 mt-1">ii first part: <b>&lt;trafficName&gt;</b>/&lt;integrationVersion&gt;/type</p>
          </div>

          <div>
            <label for="integrationVersion" class="block text-sm font-medium">Integration Version</label>
            <div
              class="mt-1 flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3"
              :class="{'ring-2 ring-rose-500': incorrectFields.includes('integrationVersion')}"
            >
              <i data-lucide="hash" class="w-4 h-4 text-gray-400 shrink-0"></i>
              <input
                id="integrationVersion"
                v-model="formData.integrationVersion"
                type="text"
                class="flex-1 bg-transparent border-0 outline-none focus:ring-0 py-2"
                placeholder="1.14.8"
              >
            </div>
            <p class="text-xs text-gray-500 mt-1">ii second part: &lt;trafficName&gt;/<b>&lt;integrationVersion&gt;</b>/type</p>
          </div>
        </div>

        <!-- Tests filter: categories + tokens + search -->
        <div>
          <div class="flex items-center justify-between">
            <label class="block text-sm font-medium">Tests Filter</label>
            <div class="flex gap-2">
              <button type="button" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                      @click="selectAllTests">All</button>
              <button type="button" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                      @click="selectNoTests">None</button>
              <button type="button" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                      :disabled="!lastRunFailures.size" @click="selectOnlyFailing">Only failing</button>
            </div>
          </div>

          <!-- Category pickers -->
          <div class="mt-2 grid grid-cols-1 gap-3">
            <!-- By Type -->
            <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-2">
              <div class="text-xs font-semibold mb-2">By Type</div>
              <div class="flex flex-wrap gap-2">
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="selectType('request')">
                  Select all Request ({{ countsByType.request || 0 }})
                </button>
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="selectType('response')">
                  Select all Response ({{ countsByType.response || 0 }})
                </button>
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="deselectType('request')">
                  Deselect Request
                </button>
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="deselectType('response')">
                  Deselect Response
                </button>
              </div>
            </div>

            <!-- By Domain (prefix before request/response) -->
            <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-2">
              <div class="text-xs font-semibold mb-2">By Domain</div>
              <div class="max-h-36 overflow-auto pr-1">
                <div v-for="dom in domainsSorted" :key="dom" class="flex items-center justify-between py-1">
                  <div class="truncate text-sm" :title="dom">{{ dom }}</div>
                  <div class="flex gap-2">
                    <button type="button"
                            class="text-xs px-2 py-0.5 rounded border border-gray-300 dark:border-gray-700"
                            @click="selectDomain(dom)">Select ({{ countsByDomain[dom] || 0 }})</button>
                    <button type="button"
                            class="text-xs px-2 py-0.5 rounded border border-gray-300 dark:border-gray-700"
                            @click="deselectDomain(dom)">Deselect</button>
                  </div>
                </div>
                <div v-if="!domainsSorted.length" class="text-xs text-gray-500">No domain prefixes detected.</div>
              </div>
            </div>

            <!-- By Region -->
            <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-2">
              <div class="text-xs font-semibold mb-2">By Region</div>
              <div class="flex flex-wrap gap-2">
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="selectRegion">
                  Select all Region ({{ countsByRegion || 0 }})
                </button>
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="deselectRegion">
                  Deselect Region
                </button>
              </div>
              <p class="text-[11px] text-gray-500 mt-1">
                Matches test names that contain <code>region</code> or <code>regions</code>.
              </p>
            </div>

            <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-2">
              <div class="text-xs font-semibold mb-2">By IP Validity</div>
              <div class="flex flex-wrap gap-2">
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="selectIPValidity">
                  Select all IP Validity ({{ countsByIPValidity || 0 }})
                </button>
                <button type="button"
                        class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                        @click="deselectIPValidity">
                  Deselect IP Validity
                </button>
              </div>
              <p class="text-[11px] text-gray-500 mt-1">
                Matches test names that contain <code>ipvX and validity</code>.
              </p>
            </div>
          </div>


          <!-- Token multiselect -->
          <div class="mt-2">
            <div class="rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 p-2">
              <div class="flex flex-wrap gap-1 mb-2 max-h-20 overflow-auto">
              <span v-for="t in formData.testsFilter" :key="t"
                    class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-200">
                {{ t }}
                <button @click="removeTest(t)" class="hover:opacity-70">&times;</button>
              </span>
              </div>
              <input type="text" v-model="testSearch" placeholder="Search tests…"
                     class="w-full px-2 py-1 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" />
              <div class="max-h-40 overflow-auto mt-2 space-y-1">
                <button v-for="t in filteredTests" :key="t"
                        class="w-full text-left px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800"
                        @click="toggleTest(t)">
                  <span class="inline-block w-4 mr-2">{{ formData.testsFilterSet.has(t) ? '✓' : '' }}</span>{{ t }}
                </button>
                <div v-if="!filteredTests.length" class="text-xs text-gray-500 px-2 py-1">No matches</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Base64 textarea -->
        <div>
          <div class="flex items-center justify-between">
            <label for="formValueText" class="block text-sm font-medium">Shareable Form Value (base64)</label>
            <div class="flex gap-2">
              <button type="button" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700"
                      @click="applyFormValueFromTextarea">Apply</button>
              <button type="button" class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700 inline-flex items-center gap-1"
                      @click="copyFormValue" :disabled="copying">
                <i data-lucide="clipboard" class="w-3.5 h-3.5"></i>
                <span v-if="!copying">Copy</span><span v-else>Copied!</span>
              </button>
            </div>
          </div>
          <textarea id="formValueText" rows="3" v-model="formValueText" @input="onFormValueTextareaInput"
                    placeholder="Paste base64-encoded JSON to populate the form"
                    class="mt-1 w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2"></textarea>
        </div>

      </div>
    </div>

    <!-- Right: results (scrollable) -->
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 shadow-card bg-white dark:bg-gray-950 p-4 overflow-auto min-h-0">
      <div class="flex flex-wrap items-center gap-3">
        <div class="text-sm flex flex-wrap items-center gap-2">
          <span class="font-semibold">Summary:</span>
          <span class="ml-1 px-2 py-0.5 rounded bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-200 inline-flex items-center gap-1">
            <i data-lucide="check-circle-2" class="w-4 h-4"></i>
            Passed {{ passedCount }}
          </span>
          <span class="px-2 py-0.5 rounded bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-200 inline-flex items-center gap-1">
            <i data-lucide="x-circle" class="w-4 h-4"></i>
            Failed {{ failedCount }}
          </span>
          <span class="px-2 py-0.5 rounded bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200 inline-flex items-center gap-1">
            <i data-lucide="list" class="w-4 h-4"></i>
            Total {{ testResult.results.length }}
          </span>
          <span class="px-2 py-0.5 rounded bg-indigo-100 text-indigo-800 dark:bg-indigo-900/40 dark:text-indigo-200 inline-flex items-center gap-1">
            <i data-lucide="clock" class="w-4 h-4"></i>
            Time {{ totalDurationMs }}ms
          </span>
        </div>
        <div class="ml-auto flex gap-2">
          <button class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700 inline-flex items-center gap-1" @click="expandAll">
            <i data-lucide="chevrons-down" class="w-4 h-4"></i>
            Expand all
          </button>
          <button class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700 inline-flex items-center gap-1" @click="collapseAll">
            <i data-lucide="chevrons-up" class="w-4 h-4"></i>
            Collapse all
          </button>
          <button class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-700 inline-flex items-center gap-1" @click="toggleShowOnlyFailed">
            <i data-lucide="filter" class="w-4 h-4"></i>
            <span v-if="showOnlyFailed">Show all</span><span v-else>Show only failed</span>
          </button>
        </div>
      </div>

      <div class="mt-3 divide-y divide-gray-200 dark:divide-gray-800">
        <div v-for="res in visibleResults" :key="res.id" class="py-2">
          <button class="w-full flex items-center justify-between text-left"
                  @click="toggleOpen(res.id)">
            <div class="font-medium">{{ res.testName }}</div>
            <div>
              <span v-if="res.passed" class="px-2 py-0.5 rounded bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-200 inline-flex items-center gap-1">
                <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                Success
              </span>
              <span v-else class="px-2 py-0.5 rounded bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-200 inline-flex items-center gap-1">
                <i data-lucide="x-circle" class="w-4 h-4"></i>
                Fail
              </span>
            </div>
          </button>
          <div v-show="openIds.has(res.id)" class="mt-2 text-sm">
            <div v-if="res.passed" class="text-gray-600 dark:text-gray-300">Took: {{ res.requestDurationMs }}ms</div>

            <div v-else>
              <div v-if="res.meta.error?.name === 'TimeoutError'" class="text-rose-700 dark:text-rose-300 font-medium">
                Timeout Error, please check your setup
              </div>

              <div v-if="res.meta.error?.name === 'NoProxyRequestReceivedError'">
                <div class="text-rose-700 dark:text-rose-300 font-medium">No request received from the proxy.</div>
                <div class="font-semibold">Request sent to the proxy:</div>
                <pre class="bg-gray-100 dark:bg-gray-800 rounded p-2 overflow-auto whitespace-pre-wrap">{{ formatRequestSentToProxy(res.meta.error.requestSentToProxy) }}</pre>
                <div class="font-semibold">Response from the proxy:</div>
                <pre class="bg-gray-100 dark:bg-gray-800 rounded p-2 overflow-auto whitespace-pre-wrap">{{ formatResponseFromProxy(res.meta.error.responseFromProxy) }}</pre>
              </div>

              <div v-if="res.meta.error?.operator === 'assert'" class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                <div><span class="font-semibold">Field:</span> {{ res.reason }}</div>
                <div>
                  <div class="font-semibold">Expected</div>
                  <pre class="bg-gray-100 dark:bg-gray-800 rounded p-2 overflow-auto whitespace-pre-wrap">{{ res.meta.error.expected }}</pre>
                </div>
                <div>
                  <div class="font-semibold">Received</div>
                  <pre class="bg-gray-100 dark:bg-gray-800 rounded p-2 overflow-auto whitespace-pre-wrap">{{ res.meta.error.actual }}</pre>
                </div>
              </div>

              <div v-if="res.meta.error?.operator === 'assertLowerThanOrEqual'" class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                <div><span class="font-semibold">Field:</span> {{ res.reason }}</div>
                <div><span class="font-semibold">Expected ≤</span> {{ res.meta.error.expected }}</div>
                <div><span class="font-semibold">Received:</span> {{ res.meta.error.actual }}</div>
              </div>

              <div v-if="res.meta.error?.operator === 'assertRegExp' || res.meta.error?.operator === 'assertToBeTruthy'" class="space-y-1">
                <div><span class="font-semibold">Field:</span> {{ res.reason }}</div>
                <div v-if="res.meta.error?.operator === 'assertRegExp'">
                  <span class="font-semibold">Expected Pattern:</span> {{ res.meta.error.expected }}
                </div>
                <div v-if="res.meta.error?.operator === 'assertToBeTruthy'">
                  <span class="font-semibold">Field Expected to be Truthy:</span> {{ res.meta.error.expected }}
                </div>
                <div v-if="res.meta.error?.actual !== undefined">
                  <span class="font-semibold">Received:</span> {{ res.meta.error.actual }}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div v-if="!visibleResults.length" class="text-sm text-gray-500 py-4">No results to display.</div>
      </div>

      <div v-if="genericError" class="mt-3 rounded-lg border border-rose-300 bg-rose-50 text-rose-800 dark:bg-rose-950/40 dark:text-rose-200 dark:border-rose-900 p-3">
        {{ genericError }}
      </div>
    </div>
  </div>

  <div class="grid">
    <div class="flex items-center gap-2">
      <span class="text-sm font-medium">Version:</span>
      <span class="px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-800"><%= version %></span>
    </div>
  </div>

  <!-- Toasts -->
  <div class="fixed bottom-4 right-4 space-y-2 z-50">
    <div v-for="t in toasts" :key="t.id"
         class="rounded-lg shadow-card px-3 py-2 text-sm"
         :class="t.variant==='error' ? 'bg-rose-100 text-rose-900 dark:bg-rose-900/50 dark:text-rose-100' :
                 t.variant==='warn' ? 'bg-amber-100 text-amber-900 dark:bg-amber-900/50 dark:text-amber-100' :
                 'bg-gray-900 text-white'">
      {{ t.message }}
    </div>
  </div>

</div>

<script>
  new Vue({
    el: '#app',
    data: {
      formData: {
        integrationUrl: '',
        ingressPath: '',
        cdnPath: '',
        trafficName: '',
        integrationVersion: '',
        testsFilter: [],
        testsFilterSet: new Set(),
      },

      formValueText: '',
      copying: false,

      _pendingTestsFilterFromFormValue: null,

      testResult: {
        status: 'initialize',
        success: false,
        results: [],
      },
      testCases: [],
      incorrectFields: [],
      genericError: null,

      // categorization index
      indexReady: false,
      byType: { request: new Set(), response: new Set(), unknown: new Set() },
      byDomain: {},            // domain -> Set(testName)
      countsByDomain: {},      // domain -> number
      countsByType: { request: 0, response: 0, unknown: 0 },
      domainsSorted: [],
      // region matching
      byRegion: new Set(),
      byIPValidity: new Set(),
      countsByRegion: 0,
      countsByIPValidity: 0,

      // UI state
      openIds: new Set(),
      showOnlyFailed: false,
      lastRunFailures: new Set(),

      // multiselect search
      testSearch: '',

      // toasts
      toasts: [],
      toastInc: 0,

      // debounce
      _updateB64Timer: null,
    },

    computed: {
      filteredTests() {
        const q = this.testSearch.trim().toLowerCase();
        if (!q) return this.testCases;
        return this.testCases.filter(t => t.toLowerCase().includes(q));
      },
      visibleResults() {
        const list = this.testResult.results;
        if (!this.showOnlyFailed) return list;
        return list.filter(r => !r.passed);
      },
      passedCount() {
        return this.testResult.results.filter(r => r.passed).length;
      },
      failedCount() {
        return this.testResult.results.filter(r => !r.passed).length;
      },
      totalDurationMs() {
        return this.testResult.results.reduce((acc, r) => {
          const duration = r.requestDurationMs || 0
          return acc > duration ? acc : duration
        }, 0);
      }
    },

    async mounted() {
      // render icons after initial mount
      if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
    },
    updated() {
      // re-render icons when DOM changes (Vue updates)
      if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
    },

    created: async function () {
      try {
        const cached = localStorage.getItem('e2e_formData');
        if (cached) {
          const obj = JSON.parse(cached);
          this.safePatchForm(obj);
        }
      } catch {}

      await this.loadTestCases();

      this.updateFormValueText();
    },

    watch: {
      formData: {
        deep: true,
        handler() {
          try {
            const toSave = { ...this.formData, testsFilterSet: undefined };
            localStorage.setItem('e2e_formData', JSON.stringify({ ...toSave }));
          } catch {}
          clearTimeout(this._updateB64Timer);
          this._updateB64Timer = setTimeout(() => this.updateFormValueText(), 200);
        }
      }
    },

    methods: {
      // ========== categorization ==========
      buildIndex() {
        // reset
        this.byType = { request: new Set(), response: new Set(), unknown: new Set() };
        this.byDomain = {};
        this.countsByDomain = {};
        this.countsByType = { request: 0, response: 0, unknown: 0 };
        this.byRegion = new Set();
        this.byIPValidity = new Set();
        this.countsByRegion = 0;
        this.countsByIPValidity = 0;

        const isTypeWord = (w) => w === 'request' || w === 'response';
        const regionRe = /\bregions?\b/i;
        const ipValidityRe = /\bipv(?!\s)[a-z0-9]+(?:[-._][a-z0-9]+)*\s+and\s+validity\b/i;

        for (const name of this.testCases) {
          const tokens = name.trim().toLowerCase().split(/\s+/);
          let type = 'unknown';
          let domain = '';

          const typeIdx = tokens.findIndex(isTypeWord);
          if (typeIdx > -1) {
            type = tokens[typeIdx];
            domain = tokens.slice(0, typeIdx).join(' ').trim();
          } else {
            domain = tokens[0] || '';
          }
          if (!domain) domain = '(uncategorized)';

          (this.byDomain[domain] ||= new Set()).add(name);
          this.byType[type].add(name);

          if (regionRe.test(name)) {
            this.byRegion.add(name);
          }

          if (ipValidityRe.test(name)) {
            this.byIPValidity.add(name)
          }
        }

        this.domainsSorted = Object.keys(this.byDomain).sort((a,b) => a.localeCompare(b));
        for (const d of this.domainsSorted) this.countsByDomain[d] = this.byDomain[d].size;
        this.countsByType.request = this.byType.request.size;
        this.countsByType.response = this.byType.response.size;
        this.countsByType.unknown = this.byType.unknown.size;

        this.countsByRegion = this.byRegion.size;
        this.countsByIPValidity = this.byIPValidity.size;

        this.indexReady = true;
      },

      selectType(type) {
        if (!this.indexReady) return;
        const add = this.byType[type] || new Set();
        this.setTestsFilter([...new Set([...this.formData.testsFilter, ...add])]);
      },
      deselectType(type) {
        if (!this.indexReady) return;
        const remove = this.byType[type] || new Set();
        const next = this.formData.testsFilter.filter(t => !remove.has(t));
        this.setTestsFilter(next);
      },
      selectDomain(domain) {
        if (!this.indexReady) return;
        const add = this.byDomain[domain] || new Set();
        this.setTestsFilter([...new Set([...this.formData.testsFilter, ...add])]);
      },
      deselectDomain(domain) {
        if (!this.indexReady) return;
        const remove = this.byDomain[domain] || new Set();
        const next = this.formData.testsFilter.filter(t => !remove.has(t));
        this.setTestsFilter(next);
      },
      selectRegion() {
        if (!this.indexReady) return;
        this.setTestsFilter([...new Set([...this.formData.testsFilter, ...this.byRegion])]);
      },
      deselectRegion() {
        if (!this.indexReady) return;
        const next = this.formData.testsFilter.filter(t => !this.byRegion.has(t));
        this.setTestsFilter(next);
      },

      selectIPValidity() {
        if (!this.indexReady) return;
        this.setTestsFilter([...new Set([...this.formData.testsFilter, ...this.byIPValidity])]);
      },
      deselectIPValidity() {
        if (!this.indexReady) return;
        const next = this.formData.testsFilter.filter(t => !this.byIPValidity.has(t));
        this.setTestsFilter(next);
      },

      // ===== helpers =====
      setTestsFilter(arr) {
        this.formData.testsFilter = Array.from(new Set(arr));
        this.formData.testsFilterSet = new Set(this.formData.testsFilter);
      },
      removeTest(t) {
        if (this.formData.testsFilterSet.has(t)) {
          this.formData.testsFilterSet.delete(t);
          this.formData.testsFilter = [...this.formData.testsFilterSet];
        }
      },
      toggleTest(t) {
        if (this.formData.testsFilterSet.has(t)) {
          this.formData.testsFilterSet.delete(t);
        } else {
          this.formData.testsFilterSet.add(t);
        }
        this.formData.testsFilter = [...this.formData.testsFilterSet];
      },
      selectAllTests() { this.setTestsFilter(this.testCases); },
      selectNoTests() { this.setTestsFilter([]); },
      selectOnlyFailing() {
        if (!this.lastRunFailures.size) return;
        const only = [...this.lastRunFailures].filter(t => this.testCases.includes(t));
        this.setTestsFilter(only);
      },

      b64encode(str) { return btoa(unescape(encodeURIComponent(str))); },
      b64decode(b64) { return decodeURIComponent(escape(atob(b64))); },

      updateFormValueText() {
        const json = JSON.stringify({
          integrationUrl: this.formData.integrationUrl,
          ingressPath: this.formData.ingressPath,
          cdnPath: this.formData.cdnPath,
          trafficName: this.formData.trafficName,
          integrationVersion: this.formData.integrationVersion,
          testsFilter: this.formData.testsFilter,
        });
        this.formValueText = this.b64encode(json);
      },

      onFormValueTextareaInput() {
        clearTimeout(this._applyTimer);
        this._applyTimer = setTimeout(() => this.applyFormValueSafe(this.formValueText), 300);
      },

      applyFormValueFromTextarea() {
        this.applyFormValueSafe(this.formValueText, { showErrors: true });
      },

      safePatchForm(obj) {
        const patch = {};
        if (typeof obj.integrationUrl === 'string') patch.integrationUrl = obj.integrationUrl;
        if (typeof obj.ingressPath === 'string') patch.ingressPath = obj.ingressPath;
        if (typeof obj.cdnPath === 'string') patch.cdnPath = obj.cdnPath;
        if (typeof obj.trafficName === 'string') patch.trafficName = obj.trafficName;
        if (typeof obj.integrationVersion === 'string') patch.integrationVersion = obj.integrationVersion;
        if (Object.keys(patch).length) {
          this.formData = { ...this.formData, ...patch, testsFilter: this.formData.testsFilter, testsFilterSet: this.formData.testsFilterSet };
        }
      },

      applyFormValueSafe(b64, opts = { showErrors: false }) {
        try {
          const decoded = this.b64decode((b64 || '').trim());
          const obj = JSON.parse(decoded);

          this.safePatchForm(obj);

          if (Array.isArray(obj.testsFilter)) {
            this._pendingTestsFilterFromFormValue = obj.testsFilter;
            if (this.testCases.length) {
              this.setTestsFilter(this._pendingTestsFilterFromFormValue.filter(t => this.testCases.includes(t)));
            }
          }
        } catch (e) {
          if (opts.showErrors) this.toast('Invalid formValue (must be base64-encoded JSON).', 'error');
        }
      },

      async copy(text) {
        try { await navigator.clipboard.writeText(text); return true; } catch { return false; }
      },

      async copyFormValue() {
        const ok = await this.copy(this.formValueText);
        if (ok) {
          this.copying = true; setTimeout(()=> this.copying=false, 900);
        } else {
          this.toast('Clipboard blocked. Select the textarea and copy manually.', 'warn');
          const el = document.getElementById('formValueText'); if (el) el.select();
        }
      },

      loadExample() {
        const example = {
          integrationUrl: 'https://example.com/integration',
          ingressPath: 'result',
          cdnPath: 'agent',
          trafficName: 'fingerprint-pro-demo',
          integrationVersion: '1.14.8',
          testsFilter: [],
        };

        this.safePatchForm(example);
        this.selectAllTests();
        this.updateFormValueText();
        this.toast('Loaded example values.');
      },

      resetForm() {
        this.formData = {
          integrationUrl: '',
          ingressPath: '',
          cdnPath: '',
          trafficName: '',
          integrationVersion: '',
          testsFilter: [],
          testsFilterSet: new Set(),
        };
        this.formValueText = '';
        this._pendingTestsFilterFromFormValue = null;
        this.updateFormValueText();
        this.toast('Form reset.');
      },

      toast(message, variant = 'default') {
        const id = ++this.toastInc;
        this.toasts.push({ id, message, variant });
        setTimeout(() => { this.toasts = this.toasts.filter(t => t.id !== id); }, 3000);
      },

      async loadTestCases() {
        try {
          const response = await fetch('/test-cases', { method: 'GET', headers: { 'Content-Type': 'application/json' }});
          if (response.ok) {
            const result = await response.json();
            this.testCases = result.data.sort((a,b)=> a.localeCompare(b));
            this.buildIndex(); // categories after loading
          } else {
            this.testCases = [];
            this.buildIndex();
            this.toast('Failed to load test cases.', 'error');
          }
        } catch {
          this.testCases = [];
          this.buildIndex();
          this.toast('Network error while loading test cases.', 'error');
        }
      },

      expandAll() {
        this.visibleResults.forEach(r => this.openIds.add(r.id));
        this.openIds = new Set(this.openIds);
      },
      collapseAll() {
        this.openIds.clear();
        this.openIds = new Set();
      },
      toggleOpen(id) {
        if (this.openIds.has(id)) this.openIds.delete(id); else this.openIds.add(id);
        this.openIds = new Set(this.openIds);
      },
      toggleShowOnlyFailed() { this.showOnlyFailed = !this.showOnlyFailed; },

      exportResults() {
        const blob = new Blob([JSON.stringify(this.testResult, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = 'e2e-test-results.json';
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
      },

      async handleSubmit() {
        this.incorrectFields = [];
        this.testResult.status = 'pending';
        this.testResult.results = [];
        this.genericError = null;

        const response = await fetch('/api/test/run-tests', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            integrationUrl: this.formData.integrationUrl,
            ingressPath: this.formData.ingressPath,
            cdnPath: this.formData.cdnPath,
            trafficName: this.formData.trafficName,
            integrationVersion: this.formData.integrationVersion,
            include: this.formData.testsFilter,
          }),
        });

        if (!response.ok) {
          if (response.status === 500) {
            try {
              const errorData = await response.json();
              this.genericError = errorData?.reason ?? 'Unknown Error';
              this.toast(this.genericError, 'error');
            } catch (_) {
              this.genericError = 'Invalid Response';
              this.toast(this.genericError, 'error');
            }
          }

          if (response.status === 400) {
            const errorData = await response.json();
            this.incorrectFields = errorData[0].errors.issues.reduce((acc, issue) => [...acc, ...issue.path], []);
            this.genericError = `Form Error, please check these fields: ${this.incorrectFields.join(', ')}`;
            this.toast('Form validation error.', 'error');
          }

          this.testResult.success = false;
        }

        if (response.ok) {
          const data = await response.json();
          const results = data.results.map((item, index) => ({ ...item, id: `element${index}` }))
            .sort((a, b) => a.id.localeCompare(b.id));
          this.testResult.results = results;
          this.testResult.success = results.every(t => t.passed === true);

          this.lastRunFailures = new Set(results.filter(r => !r.passed).map(r => r.testName));
          this.openIds = new Set(results.filter(r => !r.passed).map(r => r.id));
        }

        this.testResult.status = 'finished';
      },

      formatRequestSentToProxy(request) {
        const body = request.body ? (typeof request.body === 'string' ? request.body : JSON.stringify(request.body, null, "  ")) : ''

        return `${request.method} ${request.url}\n` +
          `${Object.entries(request.headers).filter(([name]) => !name.startsWith('x-test-case-'))
            .map(([name, value]) => `${name}: ${value}`).join('\n')}\n` +
          body
      },

      formatResponseFromProxy(response) {
        return `${response.status}\n` +
          `${Object.entries(response.headers).map(([name, value]) => `${name}: ${value}`).join('\n')}\n` +
          (typeof response.body === 'string' ? response.body : JSON.stringify(response.body, null, "  "))
      },
    },
  })
</script>
</body>
</html>
